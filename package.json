{
	"name": "nspin-extension",
	"description": "Lightweight async workflow extension for nspin with runtime-safe lifecycle utilities",
	"version": "1.0.0",
	"license": "MIT",
	"author": {
		"name": "Manuel Gil",
		"email": "support@imgil.dev",
		"url": "https://imgil.dev/"
	},
	"sponsor": {
		"url": "https://github.com/sponsors/ManuelGil"
	},
	"homepage": "https://github.com/ManuelGil/nspin-extension",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ManuelGil/nspin-extension.git"
	},
	"bugs": {
		"url": "https://github.com/ManuelGil/nspin-extension/issues"
	},
	"funding": {
		"type": "github",
		"url": "https://github.com/sponsors/ManuelGil"
	},
	"packageManager": "pnpm@10.0.0",
	"type": "module",
	"sideEffects": false,
	"engines": {
		"node": ">=22.19.0"
	},
	"keywords": [
		"async",
		"cli",
		"extension",
		"lightweight",
		"native",
		"nodejs",
		"nspin",
		"nspin-extension",
		"promise",
		"spinner",
		"terminal",
		"workflow"
	],
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"CHANGELOG.md",
		"README.md",
		"LICENSE",
		"!dist/**/*.map"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"clean": "rm -rf dist coverage *.tgz",
		"dev": "vite",
		"build": "vite build && pnpm run build:types && pnpm run build:types:cjs",
		"build:types": "tsc --emitDeclarationOnly",
		"build:types:cjs": "node ./scripts/generate-cjs-types.mjs",
		"test": "vitest run",
		"test:watch": "vitest",
		"check": "biome check .",
		"check:fix": "biome check . --write",
		"ts-check": "tsc --noEmit",
		"check-exports": "attw --pack",
		"validate": "pnpm run check && pnpm run ts-check && pnpm run test && pnpm run build && pnpm run check-exports",
		"pack:check": "pnpm pack",
		"release": "release-it",
		"prepare": "pnpm exec husky",
		"prepublishOnly": "pnpm run validate && cp README.npm.md README.md",
		"postpublish": "git checkout -- README.md"
	},
	"dependencies": {
		"nspin": "^1.8.0"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.2",
		"@biomejs/biome": "^2.4.15",
		"@commitlint/cli": "^20.5.3",
		"@commitlint/config-conventional": "^20.5.3",
		"@types/node": "^22.19.18",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"release-it": "^19.2.4",
		"typescript": "^5.9.3",
		"vite": "^8.0.11",
		"vite-plugin-dts": "^5.0.0",
		"vitest": "^3.2.4"
	},
	"lint-staged": {
		"*.{ts,js,json,md}": [
			"biome check --write"
		]
	},
	"release-it": {
		"git": {
			"commitMessage": "chore: release v${version}",
			"tagName": "v${version}",
			"requireCleanWorkingDir": true
		},
		"github": {
			"release": true
		},
		"npm": {
			"publish": false
		},
		"hooks": {
			"before:init": "pnpm run validate",
			"before:release": "pnpm run build"
		}
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"husky"
		],
		"overrides": {
			"undici@<6.24.0": ">=6.24.0"
		}
	}
}
